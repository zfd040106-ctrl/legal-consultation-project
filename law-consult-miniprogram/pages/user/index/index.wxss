.user-index-container {
  min-height: 100vh;
  background: #f5f7fb;
  display: flex;
  flex-direction: column;
}

.navbar-class {
  --td-navbar-bg-color: #ffffff;
}

.main-content {
  height: calc(100vh - 88rpx - 150rpx);
  flex: 1;
}

.page-body {
  padding: 16rpx 24rpx 0;
}

.search-card,
.carousel-card,
.quick-card,
.section-card {
  margin-bottom: 16rpx;
}

.search-card,
.quick-card,
.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.search-card {
  padding: 20rpx 24rpx;
}

.banner-swiper {
  height: 300rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-item {
  position: relative;
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 28rpx 24rpx 24rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0) 0%, rgba(15, 23, 42, 0.72) 100%);
  color: #ffffff;
}

.banner-category {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.banner-title {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.3;
}

.banner-summary {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  opacity: 0.94;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.quick-card {
  padding: 28rpx 12rpx;
}

.quick-actions {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.action-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.consultation-icon {
  background: linear-gradient(135deg, #5b8cff 0%, #3d55e6 100%);
}

.ai-icon {
  background: linear-gradient(135deg, #48c774 0%, #21a95b 100%);
}

.profile-icon {
  background: linear-gradient(135deg, #61c16f 0%, #4cab58 100%);
}

.complaint-icon {
  background: linear-gradient(135deg, #ffbc2d 0%, #f39a00 100%);
}

.action-text {
  font-size: 24rpx;
  line-height: 1.4;
  color: #334155;
  text-align: center;
}

.section-card {
  padding: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.section-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.loading-wrapper {
  display: flex;
  justify-content: center;
  padding: 56rpx 0;
}

.consultation-list {
  padding-top: 8rpx;
}

.consultation-card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #eef2f7;
}

.consultation-card:last-child {
  margin-bottom: 0;
}

.consultation-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.consultation-card-tags {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.consultation-title {
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.4;
  color: #1e293b;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.consultation-desc {
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.consultation-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f1f5f9;
}

.consultation-reply {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #4f46e5;
}

.consultation-time {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.consultation-lawyer {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f1f5f9;
}

.consultation-lawyer-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #eef2ff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
}

.consultation-lawyer-name {
  font-size: 24rpx;
  color: #334155;
  margin-right: 8rpx;
}

.consultation-lawyer-label {
  font-size: 22rpx;
  color: #94a3b8;
}

.announcement-item {
  padding: 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #f4f8ff 100%);
}

.pinned-announcement {
  background: linear-gradient(180deg, #fff9ed 0%, #fff4dc 100%);
}

.announcement-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.announcement-title-row {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.announcement-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  line-height: 1.4;
}

.announcement-time {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #94a3b8;
}

.announcement-content {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.announcement-footer {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 6rpx;
}

.announcement-link {
  font-size: 24rpx;
  color: #4f46e5;
}

.empty-wrapper {
  padding: 40rpx 0;
}

.empty-action {
  display: inline-block;
  margin-top: 20rpx;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  background: #3d55e6;
  color: #ffffff;
  font-size: 24rpx;
}

.bottom-spacing {
  height: 150rpx;
}
