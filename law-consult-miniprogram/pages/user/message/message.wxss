.message-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  display: flex;
  flex-direction: column;
}

.navbar-class {
  --td-navbar-bg-color: #FFFFFF;
}

.main-content {
  height: calc(100vh - 88rpx - 150rpx);
  padding-top: 0;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.message-tabs {
  --td-tab-nav-bg-color: #FFFFFF;
  --td-tab-item-color: #666666;
  --td-tab-item-active-color: #007AFF;
  --td-tab-track-color: #007AFF;
}

.message-list {
  flex: 1;
  padding: 16rpx 24rpx;
  box-sizing: border-box;
}

.message-list t-swipe-cell {
  display: block;
  margin-bottom: 16rpx;
}

.loading-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

.empty-wrapper {
  padding: 120rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-action {
  margin-top: 32rpx;
}

.chat-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
}

.chat-item.history {
  opacity: 0.9;
}

.avatar-wrapper {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: #E0E0E0;
}

.status-dot {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 3rpx solid #FFFFFF;
}

.status-dot.active {
  background-color: #34C759;
}

.status-dot.pending {
  background-color: #FF9500;
}

.chat-info {
  flex: 1;
  min-width: 0;
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.chat-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 16rpx;
}

.chat-time {
  font-size: 24rpx;
  color: #999999;
  flex-shrink: 0;
}

.chat-preview {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
  min-width: 0;
}

.preview-text {
  display: block;
  font-size: 28rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.chat-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999999;
  min-width: 0;
}

.chat-title text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notification-item {
  background-color: #FFFFFF;
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.notification-item.unread {
  background-color: #F8FFF9;
}

.notification-item .item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.notification-item .item-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notification-item .item-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.notification-item .item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

.notification-item .notification-type {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999999;
}

.notification-item .time-text {
  font-size: 24rpx;
  color: #CCCCCC;
}

.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #999999;
}

.no-more {
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #CCCCCC;
}

.bottom-spacing {
  height: 150rpx;
}

.delete-btn {
  height: 100% !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  background-color: #FF3B30 !important;
  color: #FFFFFF !important;
  border-radius: 0 12rpx 12rpx 0 !important;
}
