/* 咨询列表页面样式 */
.consultation-list-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.navbar-class {
  --td-navbar-bg-color: #FFFFFF;
}

/* 主内容区 */
.main-content {
  padding-top: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 88rpx - 100rpx);
}

/* 搜索栏 */
.search-section {
  padding: 16rpx 24rpx;
  background-color: #FFFFFF;
}

/* 标签页 */
.tabs-section {
  background-color: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
}

.custom-tabs {
  --td-tab-item-color: #666666;
  --td-tab-item-active-color: #007AFF;
  --td-tab-track-color: #007AFF;
}

/* 列表内容 */
.list-content {
  flex: 1;
  overflow-y: auto;
}

/* 加载状态 */
.loading-wrapper {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

/* 咨询列表 */
.consultation-list {
  padding: 16rpx 24rpx;
}

.consultation-item {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.consultation-item:active {
  background-color: #F8F8F8;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-tags {
  display: flex;
  gap: 8rpx;
}

.item-header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.item-status {
  display: flex;
}

.item-delete {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #FFF0F0;
}

.item-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

.item-time {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999999;
}

.item-time text {
  margin-left: 6rpx;
}

.item-reply {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #007AFF;
}

.item-reply text {
  margin-left: 6rpx;
}

/* 律师信息 */
.item-lawyer {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

.lawyer-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #E6F2FF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.lawyer-name {
  font-size: 26rpx;
  color: #333333;
  margin-right: 8rpx;
}

.lawyer-label {
  font-size: 22rpx;
  color: #999999;
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  padding: 24rpx 0;
}

.load-more-text {
  font-size: 24rpx;
  color: #999999;
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 24rpx 0;
}

.no-more text {
  font-size: 24rpx;
  color: #CCCCCC;
}

/* 空状态 */
.empty-wrapper {
  padding: 120rpx 0;
}

.empty-action {
  display: inline-block;
  padding: 12rpx 32rpx;
  background-color: #007AFF;
  color: #FFFFFF;
  font-size: 26rpx;
  border-radius: 8rpx;
  margin-top: 20rpx;
}

/* 悬浮按钮 */
.fab-button {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #007AFF, #5AC8FA);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.4);
}

.fab-button:active {
  transform: scale(0.95);
}

/* 底部间距 */
.bottom-spacing {
  height: 120rpx;
}
