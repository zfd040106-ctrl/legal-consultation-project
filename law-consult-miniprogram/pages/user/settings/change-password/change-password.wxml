<!-- 修改密码页面 -->
<view class="change-password-container">
  <!-- 导航栏 -->
  <t-navbar
    t-class="navbar-class"
    title="修改密码"
    left-arrow
    bind:go-back="handleBack"
  />

  <!-- 内容区域 -->
  <view class="content-section">
    <view class="info-card">
      <view class="info-icon">🔒</view>
      <view class="info-text">为了您的账户安全，请定期修改密码</view>
    </view>

    <!-- 密码表单 -->
    
    <view class="form-section">
      <!-- 当前密码 -->
      <t-input
        class="form-input"
        label="当前密码"
        layout="vertical"
        type="password"
        placeholder="请输入当前密码"
        value="{{form.currentPassword}}"
        bind:change="handleCurrentPasswordInput"
        status="{{errors.currentPassword ? 'error' : ''}}"
        tips="{{errors.currentPassword || ''}}"
      />

      <!-- 新密码 -->
      <view class="form-input password-strength-group">
        <view class="input-label">新密码</view>
        <view class="t-input-custom">
          <input
            class="input-field"
            type="password"
            placeholder="请输入新密码（6-20个字符）"
            value="{{form.newPassword}}"
            bindinput="handleNewPasswordInput"
            placeholder-class="input-placeholder"
            maxlength="20"
          />
        </view>
        <view class="hint-text">密码强度：<text class="strength-indicator {{strengthLevel}}">{{strengthText}}</text></view>
        <view wx:if="{{errors.newPassword}}" class="error-text">{{errors.newPassword}}</view>
      </view>

      <!-- 确认新密码 -->
      <t-input
        class="form-input"
        label="确认新密码"
        layout="vertical"
        type="password"
        placeholder="请再次输入新密码"
        value="{{form.confirmPassword}}"
        bind:change="handleConfirmPasswordInput"
        status="{{errors.confirmPassword ? 'error' : ''}}"
        tips="{{errors.confirmPassword || ''}}"
        maxlength="20"
      />

      <!-- 提示信息 -->
      <view class="tips-section">
        <view class="tips-title">密码要求：</view>
        <view class="tips-list">
          <view class="tips-item {{passwordValidation.hasLength ? 'valid' : ''}}">
            ✓ 至少6个字符，最多20个字符
          </view>
          <view class="tips-item {{passwordValidation.hasLower && passwordValidation.hasUpper ? 'valid' : ''}}">
            ✓ 包含大小写字母
          </view>
          <view class="tips-item {{passwordValidation.hasNumber ? 'valid' : ''}}">
            ✓ 包含数字
          </view>
        </view>
      </view>

      <!-- 确认按钮 -->
      <t-button
        class="confirm-btn"
        theme="primary"
        block
        loading="{{loading}}"
        disabled="{{loading}}"
        bindtap="handleConfirm"
      >
        {{loading ? '修改中...' : '确认修改'}}
      </t-button>

      <!-- 取消按钮 -->
      <t-button
        class="cancel-btn"
        variant="outline"
        block
        bindtap="handleBack"
      >
        取消
      </t-button>
    </view>
  </view>
</view>
