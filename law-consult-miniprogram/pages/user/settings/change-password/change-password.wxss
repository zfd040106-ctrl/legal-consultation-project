/* 修改密码页面样式 */

.change-password-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--bg-light);
}

/* 导航栏 */
.navbar-class {
  background-color: #FFFFFF;
}

/* 内容区域 */
.content-section {
  flex: 1;
  padding: 16rpx 16rpx 40rpx;
  overflow-y: auto;
}

/* 信息卡片 */
.info-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.info-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
  min-width: 48rpx;
  display: flex;
  justify-content: center;
}

.info-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

/* 表单区域 */
.form-section {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

/* 表单输入框 */
.form-input {
  margin-bottom: 16rpx;
}

/* 覆盖 t-input 默认样式 */
.form-input /deep/ .t-input__label {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.form-input /deep/ .t-input__input {
  font-size: 26rpx;
  padding: 10rpx 14rpx;
  min-height: 36rpx;
  line-height: 36rpx;
  background-color: #FFFFFF !important;
  color: var(--text-primary);
}

.form-input /deep/ .t-input__placeholder {
  font-size: 26rpx;
  color: var(--text-hint) !important;
}

.form-input /deep/ .t-input__tips {
  font-size: 22rpx;
  color: var(--danger);
  margin-top: 4rpx;
}

/* 输入框标签 */
.input-label {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 6rpx;
  display: block;
}

/* 新密码强度组 */
.password-strength-group {
  margin-bottom: 16rpx;
}

.t-input-custom {
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  background: #FFFFFF;
  padding: 10rpx 14rpx;
  margin-bottom: 8rpx;
}

.input-field {
  width: 100%;
  border: none;
  font-size: 26rpx;
  background: transparent;
  color: var(--text-primary);
  box-sizing: border-box;
  padding: 0;
}

.input-field::placeholder {
  color: var(--text-hint);
}

.input-placeholder {
  color: var(--text-hint);
}

.hint-text {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

.strength-indicator {
  font-weight: 600;
  margin-left: 6rpx;
}

.strength-indicator.weak {
  color: var(--danger);
}

.strength-indicator.medium {
  color: var(--warning);
}

.strength-indicator.strong {
  color: var(--success);
}

.error-text {
  color: var(--danger);
  font-size: 22rpx;
  margin-top: 4rpx;
}

/* 密码要求提示 */
.tips-section {
  background: rgba(255, 149, 0, 0.05);
  border-left: 4rpx solid var(--warning);
  padding: 12rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.tips-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--warning);
  margin-bottom: 8rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.tips-item {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.tips-item.valid {
  color: var(--success);
}

/* 确认按钮 */
.confirm-btn {
  margin-bottom: 8rpx;
}

.confirm-btn /deep/ .t-button {
  height: 44rpx;
  line-height: 44rpx;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 12rpx;
}

/* 取消按钮 */
.cancel-btn {
  margin-bottom: 0;
}

.cancel-btn /deep/ .t-button {
  height: 44rpx;
  line-height: 44rpx;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 12rpx;
}
