.reader-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top, rgba(59, 130, 246, 0.1), transparent 38%),
    #f5f7fb;
  display: flex;
  flex-direction: column;
}

.navbar-class {
  --td-navbar-bg-color: #ffffff;
}

.loading-wrapper,
.empty-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reader-scroll {
  flex: 1;
  height: calc(100vh - 88rpx);
}

.reader-body {
  padding: 20rpx 24rpx 40rpx;
}

.hero-card {
  position: relative;
  height: 400rpx;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 48rpx rgba(15, 23, 42, 0.12);
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.08) 0%, rgba(15, 23, 42, 0.76) 100%);
}

.hero-meta {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 28rpx;
  color: #ffffff;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  font-weight: 600;
  line-height: 1.4;
}

.hero-time {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.84);
}

.hero-time text {
  margin-left: 8rpx;
}

.article-card {
  margin-top: 20rpx;
  padding: 28rpx 30rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.article-content-card {
  padding-bottom: 30rpx;
}

.reader-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.article-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #3456d1;
  letter-spacing: 2rpx;
}

.reader-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #8a94a6;
}

.reader-page-count {
  min-width: 104rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  text-align: center;
  font-size: 22rpx;
  color: #3456d1;
  box-sizing: border-box;
}

.article-summary {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.9;
  color: #334155;
}

.reader-swiper {
  height: 820rpx;
  margin-top: 24rpx;
}

.reader-sheet {
  height: 100%;
  padding: 34rpx 28rpx 22rpx;
  border-radius: 26rpx;
  box-sizing: border-box;
  background:
    linear-gradient(180deg, rgba(52, 86, 209, 0.06) 0%, rgba(52, 86, 209, 0) 16%),
    linear-gradient(90deg, rgba(255, 255, 255, 0.96) 0%, #fffaf1 100%);
  border: 1rpx solid #e6ebf4;
  box-shadow:
    0 14rpx 28rpx rgba(15, 23, 42, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.article-paragraph {
  margin-top: 22rpx;
  font-size: 28rpx;
  line-height: 2;
  color: #1e293b;
  text-align: justify;
  text-indent: 2em;
}

.article-paragraph:first-child {
  margin-top: 0;
}

.reader-sheet-footer {
  margin-top: 28rpx;
  padding-top: 18rpx;
  border-top: 1rpx dashed #dbe3ef;
  text-align: center;
  font-size: 22rpx;
  color: #8a94a6;
}

.reader-actions {
  display: flex;
  margin-top: 24rpx;
}

.reader-action {
  flex: 1;
  padding: 18rpx 0;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
}

.reader-action + .reader-action {
  margin-left: 16rpx;
}

.reader-action-prev {
  color: #334155;
  background: #eef2f7;
}

.reader-action-next {
  color: #ffffff;
  background: linear-gradient(135deg, #5b8cff 0%, #3d55e6 100%);
}

.reader-action.is-disabled {
  opacity: 0.45;
}
