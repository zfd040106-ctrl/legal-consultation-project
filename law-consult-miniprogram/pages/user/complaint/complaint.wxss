/* 投诉建议页面样式 */
.complaint-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  display: flex;
  flex-direction: column;
}

.navbar-class {
  --td-navbar-bg-color: #FFFFFF;
}

.main-content {
  height: calc(100vh - 88rpx);
  padding-top: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 区块卡片 */
.section-card {
  background-color: #FFFFFF;
  margin: 16rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.required {
  color: #FF3B30;
}

.error-text {
  font-size: 24rpx;
  color: #FF3B30;
  margin-top: 12rpx;
}

/* 原因选择 */
.reason-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.reason-tag {
  padding: 12rpx 24rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666666;
  border: 2rpx solid transparent;
}

.reason-tag.active {
  background-color: #FFEEEE;
  color: #FF3B30;
  border-color: #FF3B30;
}

/* 关联信息 */
.related-info {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.related-info text {
  font-size: 26rpx;
  color: #666666;
  margin-left: 8rpx;
}

/* 提交区域 */
.submit-section {
  padding: 32rpx 24rpx;
}

.submit-tips {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999999;
}

.submit-tips text {
  margin-left: 8rpx;
}

/* 底部间距 */
.bottom-spacing {
  height: 60rpx;
}

/* t-textarea 高度调整为原来的两倍 */
.textarea-class {
  min-height: 240rpx !important;
}

.form-textarea /deep/ .t-textarea__wrapper {
  min-height: 240rpx !important;
}

.form-textarea /deep/ .t-textarea__wrapper-inner {
  min-height: 240rpx !important;
}

.form-textarea /deep/ .t-textarea__wrapper textarea {
  min-height: 200rpx !important;
}

.form-textarea /deep/ textarea {
  min-height: 200rpx !important;
}
