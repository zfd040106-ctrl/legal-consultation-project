/* AI法律助手页面样式 */
.ai-chat-container {
  width: 100%;
  height: 100vh;
  background-color: #F5F5F5;
  position: relative;
  overflow: hidden;
}

/* 导航栏容器 */
.navbar-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: #FFFFFF;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 状态栏占位 */
.status-bar {
  width: 100%;
  background-color: #FFFFFF;
}

/* 自定义导航栏 */
.custom-navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  background-color: #FFFFFF;
}

.navbar-left,
.navbar-right {
  display: flex;
  align-items: center;
}

.navbar-left {
  gap: 8rpx;
}

.navbar-right {
  justify-content: flex-end;
}

.navbar-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
}

.navbar-btn:active {
  background-color: #F5F5F5;
}

.navbar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

/* 聊天区域 */
.chat-area {
  position: fixed;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  box-sizing: border-box;
  background-color: #F5F5F5;
}

/* 加载中 */
.loading-section {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

/* 欢迎区域 */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 24rpx;
}

.ai-avatar-large {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E6F2FF, #CCE4FF);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: #666666;
  text-align: center;
  line-height: 1.6;
  padding: 0 24rpx;
}

/* 快捷问题 */
.quick-questions {
  width: 100%;
  margin-top: 48rpx;
}

.quick-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.quick-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.quick-item {
  background-color: #FFFFFF;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.quick-item:active {
  background-color: #F0F0F0;
}

/* 消息列表 */
.message-list {
  /* 容器 */
}

.message-item {
  display: flex;
  margin-bottom: 24rpx;
}

.user-message {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-message .message-avatar {
  background-color: #E6F2FF;
}

.user-message .message-avatar {
  background-color: #F5F5F5;
}

.message-content {
  max-width: 70%;
  margin: 0 16rpx;
}

.message-bubble {
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.ai-message .message-bubble {
  background-color: #FFFFFF;
  color: #333333;
  border-top-left-radius: 4rpx;
}

.user-message .message-bubble {
  background-color: #007AFF;
  color: #FFFFFF;
  border-top-right-radius: 4rpx;
}

.message-time {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

.user-message .message-time {
  text-align: right;
}

/* 输入中动画 */
.typing {
  padding: 20rpx 24rpx;
}

.typing-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #999999;
  border-radius: 50%;
  animation: typing 1.4s ease-in-out infinite;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% {
    opacity: 0.3;
    transform: scale(1);
  }
  30% {
    opacity: 1;
    transform: scale(1.2);
  }
}

/* 底部占位 */
.chat-bottom-spacing {
  height: 20rpx;
}

/* 输入区域 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #FFFFFF;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input-wrapper {
  flex: 1;
  background-color: #F5F5F5;
  border-radius: 40rpx;
  padding: 0 24rpx;
  margin-right: 16rpx;
}

.message-input {
  height: 72rpx;
  font-size: 28rpx;
  color: #333333;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background-color 0.2s;
}

.send-btn.active {
  background-color: #007AFF;
}

.send-btn:active {
  opacity: 0.8;
}

/* 侧边栏遮罩 */
.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.drawer-mask.show {
  opacity: 1;
  visibility: visible;
}

/* 历史记录侧边栏 */
.history-drawer {
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  width: 560rpx;
  background-color: #FFFFFF;
  z-index: 201;
  transform: translateX(-100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.history-drawer.show {
  transform: translateX(0);
}

.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #EEEEEE;
  box-sizing: border-box;
  width: 100%;
  flex-shrink: 0;
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.drawer-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.drawer-close:active {
  background-color: #F5F5F5;
}

.drawer-content {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
  overflow-x: hidden;
  overflow-y: auto;
  width: 100%;
}

/* 新建会话按钮 */
.new-chat-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background-color: #E6F2FF;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  color: #007AFF;
  font-size: 28rpx;
  font-weight: 500;
}

.new-chat-btn:active {
  background-color: #CCE4FF;
}

/* 历史会话列表 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #F9F9F9;
  border-radius: 12rpx;
  transition: background-color 0.2s;
}

.history-item:active {
  background-color: #F0F0F0;
}

.history-item.active {
  background-color: #E6F2FF;
  border: 1rpx solid #007AFF;
}

.history-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  margin-right: 16rpx;
}

.history-info {
  flex: 1;
  overflow: hidden;
}

.history-title {
  font-size: 28rpx;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 6rpx;
}

.history-time {
  font-size: 22rpx;
  color: #999;
}

.history-delete {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.history-delete:active {
  background-color: #FFE6E6;
}

/* 空历史记录 */
.empty-history {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 26rpx;
  gap: 16rpx;
}
