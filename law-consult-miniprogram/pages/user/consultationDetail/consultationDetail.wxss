.detail-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
}

.navbar-class {
  --td-navbar-bg-color: #FFFFFF;
}

.detail-content {
  flex: 1;
  width: 100%;
  padding: 16rpx 24rpx;
  box-sizing: border-box;
  overflow-y: auto;
  overflow-x: hidden;
}

.info-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  gap: 16rpx;
  min-width: 0;
}

.header-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  flex: 1;
  min-width: 0;
}

.header-time {
  font-size: 24rpx;
  color: #999999;
  flex-shrink: 0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.card-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 18rpx;
  margin-top: 18rpx;
  border-top: 1rpx solid #F3F4F6;
}

.info-label {
  font-size: 26rpx;
  color: #6B7280;
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.fee-value {
  color: #1D4ED8;
}

.pay-status {
  color: #F59E0B;
}

.card-attachments {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.attachments-title {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.attachments-title text {
  margin-left: 8rpx;
}

.attachments-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.attachment-item {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.attachment-image {
  width: 100%;
  height: 100%;
}

.attachment-file {
  width: 100%;
  height: 100%;
  background-color: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lawyer-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.lawyer-header {
  display: flex;
  align-items: center;
}

.lawyer-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #E6F2FF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.lawyer-info {
  flex: 1;
  min-width: 0;
}

.lawyer-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lawyer-title {
  font-size: 24rpx;
  color: #999999;
}

.replies-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
}

.section-title text {
  margin-left: 8rpx;
}

.reply-item {
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.reply-item:last-child {
  margin-bottom: 0;
}

.lawyer-reply {
  background-color: #E6F2FF;
}

.user-reply {
  background-color: #F5F5F5;
}

.reply-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.reply-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.reply-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-width: 0;
  gap: 12rpx;
}

.reply-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reply-time {
  font-size: 22rpx;
  color: #999999;
  flex-shrink: 0;
}

.reply-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  padding-left: 60rpx;
}

.empty-replies {
  padding: 40rpx 0;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  box-sizing: border-box;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.action-left {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  min-width: 0;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 24rpx;
}

.action-right {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.action-item text {
  font-size: 22rpx;
  color: #666666;
  margin-top: 4rpx;
}

.bottom-spacing {
  height: 120rpx;
}
