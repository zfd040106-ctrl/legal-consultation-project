<view class="edit-profile-container">
  <t-navbar
    title="编辑个人信息"
    leftArrow
    bind:left-click="handleBack"
  />

  <scroll-view class="main-content" scroll-y>
    <view class="avatar-section">
      <view class="avatar-label">头像</view>
      <view class="avatar-upload" bindtap="handleChooseAvatar">
        <t-avatar
          wx:if="{{avatarPreview || form.avatar}}"
          image="{{avatarPreview || form.avatar}}"
          size="120rpx"
        />
        <view wx:else class="avatar-placeholder">
          <t-icon name="image" size="48rpx" color="#999999" />
          <text>点击上传头像</text>
        </view>
      </view>
      <text class="form-tip">建议使用清晰的个人头像</text>
    </view>

    <view class="form-section">
      <view class="form-label">账号</view>
      <t-input
        value="{{form.account}}"
        placeholder="账号"
        disabled
        clearable="{{false}}"
      />
    </view>

    <view class="form-section">
      <view class="form-label">用户名</view>
      <t-input
        value="{{form.username}}"
        placeholder="请输入用户名"
        maxlength="20"
        clearable
        bind:change="handleUsernameChange"
      />
      <text class="form-count">{{form.username.length}}/20</text>
    </view>

    <view class="form-section">
      <view class="form-label">手机号</view>
      <t-input
        value="{{form.phone}}"
        placeholder="手机号"
        type="tel"
        disabled
        clearable="{{false}}"
      />
    </view>

    <view class="button-section">
      <t-button
        theme="primary"
        size="large"
        block
        bindtap="handleSave"
        loading="{{loading}}"
      >
        保存修改
      </t-button>
    </view>

    <view class="bottom-spacing"></view>
  </scroll-view>

  <t-toast id="t-toast" />
</view>
