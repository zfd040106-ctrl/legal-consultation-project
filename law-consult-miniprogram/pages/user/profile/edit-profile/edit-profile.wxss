.edit-profile-container {
  width: 100%;
  min-height: 100vh;
  background-color: #F5F5F5;
  display: flex;
  flex-direction: column;
}

.main-content {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
  width: 100%;
}

/* 头像上传区域 */
.avatar-section {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-label {
  width: 100%;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 24rpx;
}

.avatar-upload {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 16rpx;
  cursor: pointer;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #F5F5F5;
  border: 2rpx dashed #CCCCCC;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.avatar-placeholder text {
  font-size: 20rpx;
  color: #999999;
}

.form-tip {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  width: 100%;
}

/* 表单区域 */
.form-section {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.form-count {
  font-size: 22rpx;
  color: #999999;
  display: block;
  text-align: right;
  margin-top: 8rpx;
}

/* 按钮区域 */
.button-section {
  padding: 24rpx 0;
  margin-top: 40rpx;
}

/* 底部间距 */
.bottom-spacing {
  height: 40rpx;
}
