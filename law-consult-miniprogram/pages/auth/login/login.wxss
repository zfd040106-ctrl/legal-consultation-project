/* 登录页面样式 */

.login-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--bg-light);
}

/* 导航栏 */
.navbar-class {
  background-color: #FFFFFF;
}

/* 顶部标志区域 */
.login-header {
  width: 100%;
  height: 600rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(180deg, #f8fafc 0%, var(--bg-light) 100%);
  margin: 0;
  padding: 0;
}

/* 装饰图片 - 占满区域 */
.header-decoration {
  width: 100%;
  height: 100%;
  display: block;
}

/* 表单区域 */
.form-section {
  flex: 1;
  padding: 24rpx 32rpx 32rpx;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
}

/* 表单标题 */
.form-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

/* 表单输入框 */
.form-input {
  margin-bottom: 12rpx;
}

/* 覆盖 t-input 默认样式 - 减少标签与输入框间距 */
.form-input /deep/ .t-input {
  padding: 0;
}

.form-input /deep/ .t-input__wrap {
  padding: 0;
}

.form-input /deep/ .t-input__label {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 6rpx;
  padding: 0;
}

.form-input /deep/ .t-input__wrap--border {
  border: none;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
}

.form-input /deep/ .t-input__input {
  font-size: 26rpx;
  padding: 0;
  min-height: 32rpx;
  line-height: 32rpx;
  background-color: transparent !important;
  color: var(--text-primary);
}

.form-input /deep/ .t-input__placeholder {
  font-size: 26rpx;
  color: var(--text-hint) !important;
}

.form-input /deep/ .t-input__tips {
  font-size: 20rpx;
  color: var(--danger);
  margin-top: 4rpx;
}

/* 复选框组 */
.checkbox-group {
  margin-bottom: 16rpx;
  padding: 4rpx 0;
}

.checkbox-label {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.checkbox-label checkbox {
  margin-right: 6rpx;
  transform: scale(0.9);
}

/* 登录按钮 */
.login-btn {
  margin-bottom: 16rpx;
}

.login-btn /deep/ .t-button {
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 10rpx;
}

/* 注册链接 */
.register-link {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 12rpx 0;
  border-top: 1rpx solid var(--border);
  margin-top: auto;
}

.register-link text {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin: 0 4rpx;
}

.link-text {
  color: var(--primary);
  font-weight: 500;
}

.link-text:active {
  opacity: 0.7;
}

