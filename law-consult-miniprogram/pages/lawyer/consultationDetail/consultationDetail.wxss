.detail-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.navbar-class {
  --td-navbar-bg-color: #FFFFFF;
}

.loading-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  height: calc(100vh - 88rpx);
  padding-top: 88rpx;
}

.main-content {
  height: calc(100vh - 88rpx - 120rpx);
}

.status-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.status-bar.open,
.status-bar.pending_accept {
  background-color: #FFF5EB;
  color: #FF9500;
}

.status-bar.in_progress {
  background-color: #E6F2FF;
  color: #007AFF;
}

.status-bar.resolved {
  background-color: #E8F8EE;
  color: #34C759;
}

.status-bar.closed {
  background-color: #F5F5F5;
  color: #999999;
}

.section-card {
  background-color: #FFFFFF;
  margin: 16rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.meta-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-detail {
  margin-left: 20rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.user-phone {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666666;
}

.consultation-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.consultation-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.fee-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
  background-color: #F0FDF4;
  border-radius: 12rpx;
}

.fee-label {
  font-size: 26rpx;
  color: #166534;
}

.fee-value {
  font-size: 38rpx;
  font-weight: 700;
  color: #16A34A;
}

.info-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #6B7280;
}

.consultation-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999999;
}

.reply-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.reply-item:last-child {
  border-bottom: none;
}

.reply-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.reply-author {
  display: flex;
  align-items: center;
}

.author-info {
  margin-left: 16rpx;
}

.author-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.reply-time {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

.reply-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.empty-replies {
  padding: 40rpx 0;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.bottom-spacing {
  height: 150rpx;
}

.card-attachments {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.attachments-title {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.attachments-title text {
  margin-left: 8rpx;
}

.attachments-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.attachment-item {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.attachment-image {
  width: 100%;
  height: 100%;
}

.attachment-file {
  width: 100%;
  height: 100%;
  background-color: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
}
