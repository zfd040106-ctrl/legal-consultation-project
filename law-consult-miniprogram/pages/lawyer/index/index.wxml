<!-- 律师首页 -->
<view class="lawyer-index-container">
  <!-- 导航栏（tabBar页面不显示返回箭头） -->
  <t-navbar
    t-class="navbar-class"
    title="律师工作台"
  />

  <scroll-view class="main-content" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 律师信息卡片 -->
    <view class="lawyer-header">
      <view class="lawyer-info">
        <t-avatar
          image="{{lawyerInfo.avatar || ''}}"
          icon="{{!lawyerInfo.avatar ? 'user' : ''}}"
          size="120rpx"
        />
        <view class="lawyer-detail">
          <view class="lawyer-name">
            {{lawyerInfo.username || '律师'}}
            <t-tag
              wx:if="{{lawyerInfo.status === 'approved'}}"
              theme="success"
              size="small"
              variant="light"
            >已认证</t-tag>
            <t-tag
              wx:elif="{{lawyerInfo.status === 'pending'}}"
              theme="warning"
              size="small"
              variant="light"
            >待审核</t-tag>
          </view>
          <view class="lawyer-firm">{{lawyerInfo.firmName || '律师事务所'}}</view>
          <view class="lawyer-rating" wx:if="{{false}}">
            <t-icon name="star-filled" size="28rpx" color="#FF9500" />
            <text>{{lawyerInfo.rating || '5.0'}} 分</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 统计数据卡片 -->
    <view class="stats-card">
      <view class="stat-item" bindtap="goToConsultationList" data-status="open">
        <view class="stat-value highlight">{{stats.pendingCount || 0}}</view>
        <view class="stat-label">可接咨询</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="goToConsultationList" data-status="my">
        <view class="stat-value">{{stats.inProgressCount || 0}}</view>
        <view class="stat-label">处理中</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="goToConsultationList" data-status="my">
        <view class="stat-value">{{stats.resolvedCount || 0}}</view>
        <view class="stat-label">已解决</view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="quick-actions">
      <view class="action-item" bindtap="goToConsultationList" data-status="my">
        <view class="action-icon consultation">
          <t-icon name="chat" size="48rpx" color="#FFFFFF" />
        </view>
        <text>咨询管理</text>
      </view>
      <view class="action-item" bindtap="goToStatistics">
        <view class="action-icon statistics">
          <t-icon name="chart-bar" size="48rpx" color="#FFFFFF" />
        </view>
        <text>数据统计</text>
      </view>
      <view class="action-item" bindtap="goToProfile">
        <view class="action-icon profile">
          <t-icon name="user" size="48rpx" color="#FFFFFF" />
        </view>
        <text>个人信息</text>
      </view>
      <view class="action-item" bindtap="goToMessage">
        <view class="action-icon message">
          <t-icon name="notification" size="48rpx" color="#FFFFFF" />
        </view>
        <text>消息通知</text>
      </view>
    </view>

    <!-- 我的咨询列表 -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">我的咨询</text>
        <view class="section-more" bindtap="goToConsultationList" data-status="my">
          <text>查看全部</text>
          <t-icon name="chevron-right" size="32rpx" />
        </view>
      </view>

      <!-- 咨询列表 -->
      <view wx:if="{{myConsultations.length > 0}}">
        <view
          class="consultation-item"
          wx:for="{{myConsultations}}"
          wx:key="id"
          bindtap="goToDetail"
          data-id="{{item.id}}"
        >
          <view class="consultation-main">
            <view class="consultation-title">{{item.title}}</view>
            <view class="consultation-meta">
              <t-tag theme="primary" size="small" variant="light">{{item.category}}</t-tag>
              <t-tag
                wx:if="{{item.status === 'in_progress'}}"
                theme="primary"
                size="small"
                variant="light"
              >处理中</t-tag>
              <t-tag
                wx:elif="{{item.status === 'resolved'}}"
                theme="success"
                size="small"
                variant="light"
              >已解决</t-tag>
              <text class="consultation-time">{{item.timeText}}</text>
            </view>
            <view class="consultation-user">
              <t-icon name="user" size="24rpx" color="#999999" />
              <text>{{item.userName || '匿名用户'}}</text>
            </view>
          </view>
          <t-icon name="chevron-right" size="40rpx" color="#CCCCCC" />
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-wrapper" wx:else>
        <t-empty
          icon="check-circle"
          description="暂无咨询记录"
        />
      </view>
    </view>

    <!-- 可接咨询列表 -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">可接咨询</text>
        <view class="section-more" bindtap="goToConsultationList" data-status="open">
          <text>查看全部</text>
          <t-icon name="chevron-right" size="32rpx" />
        </view>
      </view>

      <!-- 加载中 -->
      <view class="loading-wrapper" wx:if="{{loading}}">
        <t-loading theme="circular" size="40rpx" text="加载中..." />
      </view>

      <!-- 咨询列表 -->
      <view wx:elif="{{consultations.length > 0}}">
        <view
          class="consultation-item"
          wx:for="{{consultations}}"
          wx:key="id"
          bindtap="goToDetail"
          data-id="{{item.id}}"
        >
          <view class="consultation-main">
            <view class="consultation-title">{{item.title}}</view>
            <view class="consultation-meta">
              <t-tag theme="primary" size="small" variant="light">{{item.category}}</t-tag>
              <t-tag
                theme="warning"
                size="small"
                variant="light"
              >待接单</t-tag>
              <t-tag
                wx:if="{{item.priority === 'high'}}"
                theme="danger"
                size="small"
                variant="light"
              >紧急</t-tag>
              <text class="consultation-time">{{item.timeText}}</text>
            </view>
            <view class="consultation-user">
              <t-icon name="user" size="24rpx" color="#999999" />
              <text>{{item.userName || '匿名用户'}}</text>
            </view>
          </view>
          <t-icon name="chevron-right" size="40rpx" color="#CCCCCC" />
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-wrapper" wx:else>
        <t-empty
          icon="check-circle"
          description="暂无可接咨询"
        />
      </view>
    </view>

    <!-- 底部间距 -->
    <view class="bottom-spacing"></view>
  </scroll-view>

  <!-- 底部导航栏 -->
  <lawyer-tabbar activeTab="index" unreadCount="{{unreadCount}}" bind:tabchange="handleTabChange" />
</view>
