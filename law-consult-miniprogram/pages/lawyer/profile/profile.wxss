.profile-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  display: flex;
  flex-direction: column;
}

.navbar-class {
  --td-navbar-bg-color: #FFFFFF;
}

.main-content {
  height: calc(100vh - 88rpx - 150rpx);
  padding-top: 0;
  flex: 1;
}

.lawyer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #F8F9FA 0%, #E9ECEF 100%);
  padding: 40rpx 32rpx;
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.lawyer-info {
  display: flex;
  align-items: center;
}

.lawyer-detail {
  margin-left: 24rpx;
}

.lawyer-name {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.lawyer-firm {
  font-size: 26rpx;
  color: #666666;
}

.wallet-preview {
  margin: 16rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #EEF2FF 0%, #DBEAFE 100%);
}

.wallet-preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.wallet-preview-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E3A8A;
}

.wallet-preview-grid {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.wallet-preview-item {
  flex: 1;
  padding: 20rpx;
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.72);
}

.wallet-preview-label {
  font-size: 24rpx;
  color: #64748B;
}

.wallet-preview-value {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #0F172A;
}

.menu-section {
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.logout-section {
  padding: 32rpx 24rpx;
}

.bottom-spacing {
  height: 150rpx;
}

.about-dialog {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  width: 90%;
  max-width: 1000rpx;
  padding: 0;
  overflow: hidden;
}

.about-header {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  padding: 32rpx 24rpx 16rpx;
  text-align: center;
  border-bottom: 1rpx solid #F5F5F5;
}

.about-content {
  padding: 32rpx 24rpx;
  text-align: center;
}

.app-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.app-version {
  font-size: 28rpx;
  color: #34C759;
  margin-bottom: 24rpx;
  font-weight: 500;
}

.app-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.company-info {
  border-top: 1rpx solid #F0F0F0;
  padding-top: 24rpx;
  margin-bottom: 32rpx;
}

.info-item {
  display: flex;
  justify-content: center;
  margin-bottom: 12rpx;
  font-size: 24rpx;
}

.info-label {
  color: #999999;
  margin-right: 8rpx;
}

.info-value {
  color: #333333;
  font-weight: 500;
}

.about-footer {
  padding: 0 24rpx 24rpx;
}
