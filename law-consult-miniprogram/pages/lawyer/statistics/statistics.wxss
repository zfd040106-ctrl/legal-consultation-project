.statistics-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.navbar-class {
  --td-navbar-bg-color: #FFFFFF;
}

.main-content {
  height: calc(100vh - 88rpx);
}

.time-tabs {
  background-color: #FFFFFF;
  margin-bottom: 16rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.overview-card,
.wallet-card,
.category-card {
  background-color: #FFFFFF;
  margin: 0 24rpx 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.overview-list {
  display: flex;
  flex-direction: column;
}

.overview-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.overview-label-left {
  font-size: 28rpx;
  color: #666666;
  flex: 1;
}

.overview-value-right {
  font-size: 32rpx;
  font-weight: 600;
  color: #34C759;
  text-align: right;
}

.overview-divider {
  height: 1rpx;
  background-color: #F0F0F0;
}

.wallet-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.wallet-item {
  padding: 20rpx;
  background-color: #F8FAFC;
  border-radius: 14rpx;
}

.wallet-label {
  font-size: 24rpx;
  color: #64748B;
}

.wallet-value {
  margin-top: 10rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
}

.wallet-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  padding: 18rpx 28rpx;
  border-radius: 12rpx;
  background-color: #2952E3;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
}

.sub-title {
  margin-top: 28rpx;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
}

.flow-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.flow-item:last-child {
  border-bottom: none;
}

.flow-title {
  font-size: 28rpx;
  color: #111827;
}

.flow-time {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #94A3B8;
}

.flow-amount {
  font-size: 32rpx;
  font-weight: 700;
}

.flow-amount.income {
  color: #16A34A;
}

.flow-amount.expense {
  color: #EF4444;
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.category-header {
  display: flex;
  align-items: center;
}

.category-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.category-name {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.category-count {
  font-size: 26rpx;
  color: #666666;
}

.category-progress {
  height: 8rpx;
  background-color: #F0F0F0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-left: 28rpx;
}

.category-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.no-data {
  padding: 20rpx 0;
  text-align: center;
  color: #999999;
  font-size: 26rpx;
}

.bottom-spacing {
  height: 40rpx;
}
