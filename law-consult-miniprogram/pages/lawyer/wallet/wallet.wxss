.wallet-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.navbar-class {
  --td-navbar-bg-color: #FFFFFF;
}

.wallet-content {
  height: calc(100vh - 88rpx);
}

.loading-wrapper,
.empty-wrapper,
.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

.summary-card,
.flows-card {
  margin: 16rpx 24rpx 0;
  padding: 24rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 24rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.summary-item {
  padding: 20rpx;
  border-radius: 16rpx;
  background-color: #F8FAFC;
}

.summary-label {
  font-size: 24rpx;
  color: #64748B;
}

.summary-value {
  margin-top: 10rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
}

.action-row {
  margin-top: 24rpx;
  display: flex;
}

.flow-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.flow-item:last-child {
  border-bottom: none;
}

.flow-title {
  font-size: 28rpx;
  color: #1F2937;
}

.flow-time {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #94A3B8;
}

.flow-amount {
  font-size: 32rpx;
  font-weight: 700;
}

.flow-amount.income {
  color: #16A34A;
}

.flow-amount.expense {
  color: #EF4444;
}
