/* 启动页样式 */

.splash-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* 背景图片 */
.splash-background {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* 半透明遮罩层 - 增强文字可读性 */
.splash-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(0, 50, 100, 0.3) 0%, rgba(0, 80, 150, 0.5) 100%);
  z-index: 2;
}

/* 内容区域 */
.splash-content {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  width: 100%;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

/* Logo 部分 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.app-name {
  font-size: 64rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  letter-spacing: 8rpx;
  text-shadow: 2rpx 2rpx 8rpx rgba(0, 0, 0, 0.3);
  font-family: "STKaiti", "KaiTi", "楷体", serif;
}

.app-tagline {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 4rpx;
  font-family: "STKaiti", "KaiTi", "楷体", serif;
}

/* 点击提示 */
.tap-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 62rpx;
  flex: 1;
  justify-content: flex-end;
}

.tap-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 16rpx 48rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 40rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 0.7;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
}

/* 底部信息 */
.splash-footer {
  position: absolute;
  bottom: 60rpx;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.footer-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.version-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}
